{
  "name": "@samuelf27/data-structures",
  "version": "1.0.0",
  "description": "Estruturas de dados e algoritmos clássicos implementados em TypeScript, com tipagem genérica e testes.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["typescript", "data-structures", "algorithms", "computer-science", "big-o", "estrutura-de-dados"],
  "author": "Samuel Ferreira",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/Samuelf27/data-structures-typescript.git" },
  "publishConfig": { "access": "public" },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
